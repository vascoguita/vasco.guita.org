---
import ContactCTA from '../components/ContactCTA.astro';
import Hero from '../components/Hero.astro';
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="About | Vasco Guita" description="About Vasco Guita">
	<div class="stack gap-20">
		<main class="wrapper about">
			<Hero
				title="About"
				tagline="Thanks for stopping by. Read below to learn more about myself and my background."
			>
				<img
					width="1553"
					height="873"
					src="/assets/at-work.jpg"
					alt="Vasco Guita"
				/>
			</Hero>

			<section>
				<h2 class="section-title">Background</h2>
				<div class="content">
					<p>
						I'm a software engineer with 8+ years of experience in DevOps, automation,
						infrastructure, and system administration. I'm currently based in Geneva,
						Switzerland, where I work as an Onboarding Specialist at SonarSource, leading
						enterprise customer adoption of code quality and security tooling.
					</p>
					<p>
						Before joining SonarSource, I spent four years at CERN as a Software Engineer,
						where I owned automation, infrastructure, and observability programs spanning
						FPGA test labs for particle accelerators, large-scale storage services used by
						30,000+ users, and CERN's Open Hardware Repository.
					</p>
					<p>
						I hold an M.Sc. in Computer Science and Engineering from IST, Universidade de
						Lisboa, with a specialization in Cyber-Security and Cyber-physical Systems.
						My thesis on Data Recovery for Hardware Security Extensions was graded 20/20.
					</p>
				</div>
			</section>
			<section>
				<h2 class="section-title">Education</h2>
				<div class="content">
					<p><strong>M.Sc. Computer Science and Engineering</strong> — IST, Universidade de Lisboa (2018–2021)</p>
					<p>Specialization in Cyber-Security and Cyber-physical Systems. Erasmus: 1 year at Politechnika Lubelska, Poland.</p>
					<p><strong>B.Sc. Computer Science and Engineering</strong> — IST, Universidade de Lisboa (2015–2018)</p>
				</div>
			</section>
			<section>
				<h2 class="section-title">Languages</h2>
				<div class="content">
					<p>Portuguese (C2), English (C2), French (B1), German (B1), and Polish (A1).</p>
				</div>
			</section>
			<section>
				<h2 class="section-title">Interests</h2>
				<div class="content">
					<p>Custom PCB design and prototyping, self-hosted homelab, 3D modeling and printing, model rocketry and aeromodeling, and singing in a Polish choir.</p>
				</div>
			</section>
		</main>

		<ContactCTA />
	</div>
</BaseLayout>

<style>
	.about {
		display: flex;
		flex-direction: column;
		gap: 3.5rem;
	}

	img {
		margin-top: 1.5rem;
		border-radius: 1.5rem;
		box-shadow: var(--shadow-md);
	}

	section {
		display: flex;
		flex-direction: column;
		gap: 0.5rem;
		color: var(--gray-200);
	}

	.section-title {
		grid-column-start: 1;
		font-size: var(--text-xl);
		color: var(--gray-0);
	}

	.content {
		grid-column: 2 / 4;
	}

	.content :global(a) {
		text-decoration: 1px solid underline transparent;
		text-underline-offset: 0.25em;
		transition: text-decoration-color var(--theme-transition);
	}

	.content :global(a:hover),
	.content :global(a:focus) {
		text-decoration-color: currentColor;
	}

	@media (min-width: 50em) {
		.about {
			display: grid;
			grid-template-columns: 1fr 60% 1fr;
		}

		.about > :global(:first-child) {
			grid-column-start: 2;
		}

		section {
			display: contents;
			font-size: var(--text-lg);
		}
	}
</style>
